# SvelteKit private env vars (server-side only) — copy to .env and fill in
# Point to the .NET backend
API_URL=http://localhost:8000

# API key proving calls come from this BFF (must match backend ApiSettings:ApiKey)
# Generate with: openssl rand -base64 48
API_SECRET=

# --- Sentry ---
# Frontend DSN (public, browser-safe) from Sentry > medika-frontend > Client Keys (DSN).
# Leave blank locally to disable Sentry; set per-environment in Vercel for deployments.
PUBLIC_SENTRY_DSN=
# Environment label: development | preview | production
PUBLIC_SENTRY_ENV=development
# Build-only token for source-map upload (Sentry > Settings > Auth Tokens).
# Needed only when building/deploying, not for local dev. Keep OUT of git.
SENTRY_AUTH_TOKEN=
