# Normalize all text files to LF in the repository (kills CRLF/LF churn).
# Default: detect text, store as LF, and check out as LF on every platform.
* text=auto eol=lf

# Explicit text types — stored and checked out as LF
*.cs      text eol=lf
*.csproj  text eol=lf
*.props   text eol=lf
*.targets text eol=lf
*.slnx    text eol=lf
*.sln     text eol=lf
*.ts      text eol=lf
*.tsx     text eol=lf
*.js      text eol=lf
*.mjs     text eol=lf
*.cjs     text eol=lf
*.svelte  text eol=lf
*.json    text eol=lf
*.jsonc   text eol=lf
*.md      text eol=lf
*.css     text eol=lf
*.scss    text eol=lf
*.html    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.sh      text eol=lf
*.http    text eol=lf
*.env     text eol=lf

# Windows-only scripts keep CRLF
*.ps1     text eol=crlf
*.psm1    text eol=crlf
*.bat     text eol=crlf
*.cmd     text eol=crlf

# Binary — never normalize
*.webp    binary
*.pdf     binary
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.eot     binary
*.otf     binary
*.pfx     binary
*.snk     binary
